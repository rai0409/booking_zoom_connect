# Shared
BASE_URL=http://localhost:3000
NODE_ENV=development

# API (web proxy)
API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/<POSTGRES_DB>?schema=public

# App Insights (prod only; local uses console)
APPINSIGHTS_CONNECTION_STRING=

# Microsoft Graph (multi-tenant app)
# App-only (admin consent) client credentials
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Send mail as this mailbox (recommended: a dedicated shared mailbox for bookings)
MS_SHARED_MAILBOX=
# If you implement admin consent callback endpoints, set redirect here
MS_AUTH_REDIRECT_URI=http://localhost:4000/v1/tenants/callback

# Feature flags
GRAPH_ENABLED=1
ZOOM_ENABLED=0

# Zoom S2S OAuth (future)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Queue
QUEUE_DRIVER=memory   # memory | servicebus
SERVICEBUS_CONNECTION=
SERVICEBUS_QUEUE_NAME=graph-webhooks

# Admin API key for internal attendance
ADMIN_API_KEY=
JWT_SECRET=

# Mock flags (local dev)
GRAPH_MOCK=true
ZOOM_MOCK=true
